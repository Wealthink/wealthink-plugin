{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session_start.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_wealthink_wealthink__set_.*visibility",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/publish_gate.py\""
          }
        ]
      },
      {
        "matcher": "mcp__plugin_wealthink_wealthink__archive_.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/archive_gate.py\""
          }
        ]
      }
    ]
  }
}
